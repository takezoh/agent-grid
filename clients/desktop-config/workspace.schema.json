{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Grid Workspace configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "idle_quit_seconds", "default_window"],
  "properties": {
    "schema_version": { "const": 1 },
    "idle_quit_seconds": { "type": "integer", "minimum": 0, "maximum": 86400 },
    "default_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 320, "maximum": 16384 },
        "height": { "type": "integer", "minimum": 240, "maximum": 16384 }
      }
    }
  }
}
