{
  "version": 2,
  "profiles": [
    {"name":"save","tier":"T0","commands":[
      {"id":"harness-policy","group":"core","command":"cd src && go test ./internal/harnesspolicy ./gorules"}
    ]},
    {"name":"pre-push","tier":"T0-T2 changed","commands":[
      {"id":"dependency-admission","group":"core","command":"scripts/check-harness-dependencies.sh"},
      {"id":"skip-inventory","group":"core","command":"scripts/check-test-skips.sh"},
      {"id":"repeat-changed","group":"core","command":"scripts/repeat-changed-tests.sh"}
    ]},
    {"name":"pr","tier":"T0-T2 full","commands":[
      {"id":"web-gate","group":"core","command":"cd src/client/web && npm ci && npx playwright install chromium && npm run test:web"},
      {"id":"wire-fixtures","group":"core","command":"cd src && go test ./server/api -run TestWireFixtures -count=1 -args -update && git diff --exit-code -- client/web/src/wire/testdata && test -z \"$(git status --porcelain -- client/web/src/wire/testdata)\""},
      {"id":"go-vet","group":"core","command":"cd src && go vet ./..."},
      {"id":"e2e-vet","group":"core","command":"scripts/vet-go-e2e.sh"},
      {"id":"e2e-siblings","group":"core","command":"scripts/check-e2e-siblings.sh"},
      {"id":"dependency-admission","group":"core","command":"scripts/check-harness-dependencies.sh"},
      {"id":"skip-inventory","group":"core","command":"scripts/check-test-skips.sh"},
      {"id":"repeat-changed","group":"core","when":"pull-request","command":"scripts/repeat-changed-tests.sh"},
      {"id":"trusted-tampering","group":"core","when":"pull-request","command":"scripts/run-trusted-harness-gate.sh \"$BASE_REF\""},
      {"id":"mutation","group":"core","command":"scripts/run-mutation-pilot.sh"},
      {"id":"go-test","group":"core","command":"cd src && go test ./..."},
      {"id":"coverage","group":"core","command":"scripts/check-coverage.sh"},
      {"id":"build","group":"core","command":"make build-all"},
      {"id":"lint","group":"core","command":"make lint"},
      {"id":"web-build-for-race","group":"race","command":"cd src/client/web && npm ci && npm run build"},
      {"id":"race","group":"race","command":"make test-race"},
      {"id":"web-build-for-fuzz","group":"fuzz","command":"cd src/client/web && npm ci && npm run build"},
      {"id":"fuzz-stream","group":"fuzz","command":"cd src && go test -run '^$' -fuzz '^FuzzStreamRouting$' -fuzztime=30s ./client/runtime/subsystem/stream/"},
      {"id":"fuzz-state","group":"fuzz","command":"cd src && go test -run '^$' -fuzz '^FuzzReduce$' -fuzztime=30s ./client/state/"},
      {"id":"fuzz-web","group":"fuzz","command":"cd src && go test -run '^$' -fuzz '^FuzzApplyInboundProto$' -fuzztime=30s ./server/api/"},
      {"id":"fuzz-osc","group":"fuzz","command":"cd src && go test -run '^$' -fuzz '^FuzzParseOsc$' -fuzztime=30s ./client/runtime/"},
      {"id":"schema-drift","group":"schema","command":"make codex-schema-check"}
    ]},
    {"name":"nightly","tier":"T3","commands":[
      {"id":"nightly-fidelity","group":"core","command":"scripts/run-nightly-e2e-report.sh"}
    ]}
  ]
}
