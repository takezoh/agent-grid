{
  "name": "agent-grid-web",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vite build && touch dist/.gitkeep",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest",
    "test:unit": "vitest --run --allowOnly false",
    "test:coverage": "vitest --run --allowOnly false --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:screenshots": "npm run build && AG_E2E_SCREENSHOTS=1 playwright test e2e/screenshots.spec.ts",
    "test:web": "npm run lint && npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@replit/codemirror-vim": "^6.3.0",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "mermaid": "^11.16.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.56.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.1.0",
    "@types/node": "^22.20.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react-swc": "3.7.2",
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "15.11.7",
    "typescript": "5.7.2",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  },
  "allowScripts": {
    "@biomejs/biome@1.9.4": true,
    "@swc/core@1.15.41": true,
    "esbuild@0.21.5": true
  }
}
