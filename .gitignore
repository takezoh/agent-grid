src/arc
src/bridge
src/orchestrator
src/claude-app-server
# The patterns above ignore the built binaries (e.g. `src/orchestrator`), but
# `src/orchestrator` also matches the orchestrator source package directory, and
# `bridge` matches `src/cmd/bridge/`. Re-include the directories
# (trailing slash = dirs only) so their sources are tracked; the binaries, being
# regular files, stay ignored.
!src/orchestrator/
!src/cmd/arc/
!src/cmd/bridge/
notify.ps1
arc.log
.agent-grid/worktrees/
.agent-grid/settings.toml
go.work
go.work.sum

# Node / web client build cache (root-level — created when running npm/pnpm/vite
# from the repo root instead of src/client/web/). Sources live under src/client/
# web/ where the package.json is; nothing at repo root needs tracking.
node_modules/
.pnpm-store/

# Local tooling / editor / shell / agent configuration — not project-shared.
.claude/
.codex
.codex-e2e-home-*/
.playwright-mcp/
.mcp.json
mise.toml
.idea
.vscode
.bash_profile
.bashrc
.profile
.zprofile
.zshrc
.gitconfig
.ripgreprc
