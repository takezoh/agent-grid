roost
roost-bridge
sockbridge
/orchestrator
/claude-app-server
src/roost
src/roost-bridge
src/orchestrator
src/claude-app-server
# The patterns above ignore the built binaries (e.g. `src/orchestrator`), but
# `src/orchestrator` also matches the orchestrator source package directory, and
# `roost-bridge` matches `src/cmd/roost-bridge/`. Re-include the directories
# (trailing slash = dirs only) so their sources are tracked; the binaries, being
# regular files, stay ignored.
!src/orchestrator/
!src/cmd/roost/
!src/cmd/roost-bridge/
notify.ps1
roost.log
.roost/worktrees/
.roost/settings.toml
go.work
go.work.sum

# Local tooling / editor / shell / agent configuration — not project-shared.
.claude/
.codex
.playwright-mcp/
.mcp.json
mise.toml
.idea
.vscode
.bash_profile
.bashrc
.profile
.zprofile
.zshrc
.gitconfig
.ripgreprc
