{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-module.local/docs/_relations.schema.json",
  "title": "Well-known relation edge types and their inverse pairs",
  "description": "Reference document for canonical edge vocabulary. Borrowed from Backstage Software Catalog well-known relations. Each pair is bidirectional; the writer of the forward edge should also write the inverse edge on the target document.",
  "type": "object",
  "properties": {
    "pairs": {
      "type": "object",
      "additionalProperties": {"type": "string"},
      "examples": [{
        "dependsOn":   "dependencyOf",
        "partOf":      "hasPart",
        "implements":  "implementedBy",
        "supersedes":  "supersededBy",
        "references":  "referencedBy",
        "blocks":      "blockedBy",
        "ownedBy":     "owns",
        "providesApi": "consumesApi"
      }]
    }
  },
  "pairs": {
    "dependsOn":   "dependencyOf",
    "partOf":      "hasPart",
    "implements":  "implementedBy",
    "supersedes":  "supersededBy",
    "references":  "referencedBy",
    "blocks":      "blockedBy",
    "ownedBy":     "owns",
    "providesApi": "consumesApi"
  },
  "acyclic_types": ["dependsOn", "blocks", "partOf", "supersedes"]
}
